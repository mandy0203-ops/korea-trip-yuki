<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Korea Trip Yuki — Mandy × 雅雅</name>
    <description>2026/6/4-6/6 首爾旅遊（10 個真實座標地點，分 4 群組）</description>

    <Style id="hotelStyle">
      <IconStyle>
        <color>ff4d4dc1</color>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="d1Style">
      <IconStyle>
        <color>ffa57c3a</color>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/blu-circle.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="d2Style">
      <IconStyle>
        <color>ffb8a5d4</color>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/pink-circle.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="d3Style">
      <IconStyle>
        <color>ff20a5da</color>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/ylw-circle.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="foodStyle">
      <IconStyle>
        <color>ff80906b</color>
        <Icon><href>https://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href></Icon>
